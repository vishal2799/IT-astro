---
const APP_URL = import.meta.env.APP_URL ?? '';
---

<div class='bg-white rounded-lg shadow-md p-8'>
  <h2 class='text-2xl font-bold mb-6 text-gray-900'>Send Us a Message</h2>

  <!-- Success Message (hidden by default) -->
  <div id='form-success' class='hidden mb-6 p-4 bg-green-50 border border-green-200 rounded-md text-green-800 text-sm'>
    ✅ Thank you! We've received your message and will get back to you within 24 hours.
  </div>

  <!-- Error Message (hidden by default) -->
  <div id='form-error' class='hidden mb-6 p-4 bg-red-50 border border-red-200 rounded-md text-red-800 text-sm'>
    ❌ Something went wrong. Please try again or email us directly at
    <a href='mailto:contact@alicorninfotech.com' class='underline'>contact@alicorninfotech.com</a>.
  </div>

  <form
    id='contact-form'
    class='space-y-6'
    aria-labelledby='form-heading'
    novalidate
  >
    <!-- Web3Forms access key — get yours free at https://web3forms.com -->
    <input type='hidden' name='access_key' value={import.meta.env.WEB3FORMS_KEY ?? 'YOUR_WEB3FORMS_ACCESS_KEY'} />
    <input type='hidden' name='subject' value='New Contact Form Submission — Alicorn Infotech' />
    <input type='hidden' name='from_name' value='Alicorn Infotech Website' />
    <!-- Honeypot spam protection -->
    <input type='checkbox' name='botcheck' class='hidden' style='display:none' tabindex='-1' autocomplete='off' />

    <!-- Name Field -->
    <div>
      <label for='name' class='block text-sm font-medium text-gray-700 mb-1' id='name-label'>
        Name <span class='text-red-500'>*</span>
      </label>
      <input
        type='text' id='name' name='name' required placeholder='Your full name'
        class='w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-primary focus:border-primary'
        aria-required='true' aria-describedby='name-label'
      />
    </div>

    <!-- Email Field -->
    <div>
      <label for='email' class='block text-sm font-medium text-gray-700 mb-1' id='email-label'>
        Email <span class='text-red-500'>*</span>
      </label>
      <input
        type='email' id='email' name='email' required placeholder='you@example.com'
        class='w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-primary focus:border-primary'
        aria-required='true' aria-describedby='email-label'
      />
    </div>

    <!-- Phone Field -->
    <div>
      <label for='phone' class='block text-sm font-medium text-gray-700 mb-1' id='phone-label'>
        Phone (optional)
      </label>
      <input
        type='tel' id='phone' name='phone' placeholder='Your phone number'
        class='w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-primary focus:border-primary'
        aria-describedby='phone-label'
      />
    </div>

    <!-- Message Field -->
    <div>
      <label for='message' class='block text-sm font-medium text-gray-700 mb-1' id='message-label'>
        Message <span class='text-red-500'>*</span>
      </label>
      <textarea
        id='message' name='message' rows='4' required placeholder='Write your message here...'
        class='w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-primary focus:border-primary'
        aria-required='true' aria-describedby='message-label'></textarea>
    </div>

    <!-- Service Type -->
    <div>
      <label for='service' class='block text-sm font-medium text-gray-700 mb-1'>
        What do you need help with? <span class='text-gray-400'>(optional)</span>
      </label>
      <select id='service' name='service'
        class='w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-primary focus:border-primary bg-white'>
        <option value=''>Select a service...</option>
        <option value='Custom Software Development'>Custom Software Development</option>
        <option value='Business Automation'>Business Automation / Power Platform</option>
        <option value='AI Integration'>AI Integration</option>
        <option value='QA & Testing'>QA &amp; Testing</option>
        <option value='Mobile App'>Mobile App Development</option>
        <option value='Web Development'>Web Development</option>
        <option value='Not sure'>Not sure yet</option>
      </select>
    </div>

    <!-- Budget -->
    <div>
      <label for='budget' class='block text-sm font-medium text-gray-700 mb-1'>
        Rough project budget <span class='text-gray-400'>(optional)</span>
      </label>
      <select id='budget' name='budget'
        class='w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-primary focus:border-primary bg-white'>
        <option value=''>Select a range...</option>
        <option value='Under $5K'>Under $5,000</option>
        <option value='$5K-$15K'>$5,000 – $15,000</option>
        <option value='$15K-$50K'>$15,000 – $50,000</option>
        <option value='$50K+'>$50,000+</option>
      </select>
    </div>

    <!-- Submit Button -->
    <div>
      <button
        type='submit' id='submit-btn'
        class='w-full bg-primary text-white font-bold py-3 px-4 rounded-md hover:bg-primary-700 transition duration-300 focus:ring-2 focus:ring-primary focus:ring-offset-2 disabled:opacity-60 disabled:cursor-not-allowed'
        aria-label='Send your message'
      >
        <span id='btn-text'>Send Message</span>
        <span id='btn-loading' class='hidden'>Sending...</span>
      </button>
      <p class='text-sm text-gray-500 mt-3 text-center'>
        We respond to all enquiries within 24 hours, Monday to Friday (IST). For urgent requests, email
        <a href='mailto:contact@alicorninfotech.com' class='text-primary hover:underline'>contact@alicorninfotech.com</a> directly.
      </p>
    </div>
  </form>
</div>

<script define:vars={{ APP_URL }}>
  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('submit-btn');
  const btnText = document.getElementById('btn-text');
  const btnLoading = document.getElementById('btn-loading');
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Show loading state
    submitBtn.disabled = true;
    btnText.classList.add('hidden');
    btnLoading.classList.remove('hidden');
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    try {
      const formData = new FormData(form);
      const data = Object.fromEntries(formData);

      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(data),
      });

      const result = await response.json();

      if (response.ok && result.success) {
        window.location.href = (APP_URL || '') + '/thank-you';
      } else {
        throw new Error(result.message || 'Submission failed');
      }
    } catch (err) {
      console.error('Form error:', err);
      errorMsg.classList.remove('hidden');
      errorMsg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    } finally {
      submitBtn.disabled = false;
      btnText.classList.remove('hidden');
      btnLoading.classList.add('hidden');
    }
  });
</script>
