---
import MainLayout from '../layouts/MainLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TechCard from '../components/TechCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import CTA from '../components/CTA.astro';
import {
  posts,
  projects,
  services,
  testimonials,
  technology,
} from '../constants';
import { Image } from 'astro:assets';
import BlogPostCard from '../components/BlogPostCard.astro';
import HomeHeroImage from '../assets/images/HomeHero.webp';
import HomeAboutImage from '../assets/images/HomeAbout.webp';
//favicon, image optimize webp, font local, seo, thank you, error page, testing, form integrate
---

<MainLayout
  title='Alicorn Infotech — Software Development, AI Integration & Automation for Startups'
  description='Alicorn Infotech is a software development team in Pune, India. We build web and mobile products, integrate AI, automate workflows and run QA for startups and growing businesses in the US, UK, Australia and India.'
>
  <main>
    <!-- Hero Section -->
    <section
      class='relative h-[70vh] min-h-[500px] flex items-center justify-center'
    >
      <Image
        src={HomeHeroImage}
        alt='Alicorn Infotech'
        width={1920}
        height={1080}
        class='absolute inset-0 w-full h-full object-cover'
      />
      <!-- <img
        src='/service21.jpg'
        alt='Alicorn Solutions'
        class='absolute inset-0 w-full h-full object-cover'
      /> -->
      <div
        class='absolute inset-0 bg-gradient-to-r from-primary/80 to-primary-dark/80'
      >
      </div>
      <div class='relative z-10 text-center text-white px-4 max-w-4xl mx-auto'>
        <h1 class='text-4xl md:text-6xl font-bold mb-6'>
          Your dedicated tech team — without the big firm price tag.
        </h1>
        <p class='text-xl md:text-2xl mb-8'>
          We build software, automate processes and run QA for growing startups. Clients in the US, UK, Australia and India.
        </p>
        <div class='flex flex-wrap justify-center gap-4'>
          <a
            href='/portfolio'
            class='bg-white text-primary hover:bg-white hover:text-primary-400 font-bold py-3 px-8 rounded-full transition duration-300 text-lg'
            >See Our Work</a
          >
          <a
            href='https://calendly.com/tarun-parashar-alicorninfotech/30min'
            target='_blank'
            rel='noopener noreferrer'
            class='bg-transparent border-2 border-white text-white hover:bg-white/10 font-bold py-3 px-8 rounded-full transition duration-300 text-lg'
            >Book a Free Call</a
          >
        </div>
      </div>
    </section>

    <!-- Trust Bar -->
    <section class='bg-white border-b border-gray-100 py-6 px-4'>
      <div class='container mx-auto max-w-5xl'>
        <div class='flex flex-wrap justify-center items-center gap-8 md:gap-16 text-center'>
          <div>
            <span class='text-3xl font-bold text-primary'>14+</span>
            <p class='text-sm text-gray-500 mt-1'>Projects Delivered</p>
          </div>
          <div class='hidden sm:block w-px h-10 bg-gray-200'></div>
          <div>
            <span class='text-3xl font-bold text-primary'>5+</span>
            <p class='text-sm text-gray-500 mt-1'>Years in Operation</p>
          </div>
          <div class='hidden sm:block w-px h-10 bg-gray-200'></div>
          <div>
            <span class='text-3xl font-bold text-primary'>4</span>
            <p class='text-sm text-gray-500 mt-1'>Countries: US, UK, AUS, India</p>
          </div>
          <div class='hidden sm:block w-px h-10 bg-gray-200'></div>
          <div>
            <span class='text-3xl font-bold text-primary'>3</span>
            <p class='text-sm text-gray-500 mt-1'>Active Ongoing Projects</p>
          </div>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section class='section-padding px-4'>
      <div class='container mx-auto max-w-6xl'>
        <div class='flex flex-col md:flex-row items-center gap-12'>
          <div class='md:w-1/2'>
            <h2 class='text-3xl md:text-4xl font-bold mb-6 text-gray-900'>
              About Alicorn Infotech
            </h2>
            <p class='text-lg text-gray-700 mb-6'>
              Alicorn Infotech is a software development team based in Pune, India. We work with startups and growing businesses across the US, UK, Australia and India — building web and mobile products, integrating AI, automating manual processes, and running QA.
            </p>
            <p class='text-lg text-gray-700 mb-6'>
              Our team is small by design. The co-founders are involved in every project — which means the people you speak to are the same people building your product. No account managers. No handoffs to junior developers.
            </p>
            <a
              href='/about-us'
              class='inline-block bg-primary hover:bg-primary-dark text-white font-bold py-3 px-8 rounded-full transition duration-300 text-lg'
              >Learn More About Us</a
            >
          </div>
          <div class='md:w-1/2'>
            <Image
              src={HomeAboutImage}
              alt='About Alicorn Infotech'
              width={600}
              height={400}
              class='rounded-lg shadow-xl'
            />
          </div>
        </div>
      </div>
    </section>

    <!-- AI Positioning Banner -->
    <section class='bg-gradient-to-r from-primary to-primary-dark py-12 px-4'>
      <div class='container mx-auto max-w-5xl flex flex-col md:flex-row items-center justify-between gap-8'>
        <div class='text-white'>
          <span class='inline-block bg-white/20 text-white text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full mb-3'>New in 2026</span>
          <h2 class='text-2xl md:text-3xl font-bold mb-2'>We now build AI into your product or workflow.</h2>
          <p class='text-white/80 max-w-xl'>
            LLM-powered chatbots, document intelligence, AI workflow automation — integrated into what you already have. Practical AI, not demos. Scoped in weeks, not months.
          </p>
        </div>
        <a
          href='/services/ai-integration'
          class='flex-shrink-0 bg-white text-primary font-bold py-3 px-8 rounded-full hover:bg-gray-100 transition duration-300 text-center'
        >
          See AI Services →
        </a>
      </div>
    </section>

    <!-- How We Work -->
    <section class='section-padding px-4 bg-gray-50'>
      <div class='container mx-auto max-w-5xl'>
        <h2 class='text-3xl md:text-4xl font-bold text-center mb-4 text-gray-900'>How We Work</h2>
        <p class='text-center text-gray-500 mb-14 max-w-2xl mx-auto'>No long onboarding. No handoffs to people you haven't met. Here's how a typical engagement runs.</p>
        <div class='grid grid-cols-1 md:grid-cols-3 gap-8'>
          <div class='relative bg-white rounded-xl shadow-sm p-8 border border-gray-100'>
            <div class='w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mb-5'>
              <span class='text-2xl font-bold text-primary'>1</span>
            </div>
            <h3 class='text-xl font-bold text-gray-900 mb-3'>Discovery Call</h3>
            <p class='text-gray-600 leading-relaxed'>Book a free 30-minute call. We'll listen, ask the right questions, and give you an honest estimate — not a sales pitch.</p>
          </div>
          <div class='relative bg-white rounded-xl shadow-sm p-8 border border-gray-100'>
            <div class='w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mb-5'>
              <span class='text-2xl font-bold text-primary'>2</span>
            </div>
            <h3 class='text-xl font-bold text-gray-900 mb-3'>Scoped Build</h3>
            <p class='text-gray-600 leading-relaxed'>We deliver in defined sprints with clear milestones. No surprise invoices. No scope creep without your explicit sign-off.</p>
          </div>
          <div class='relative bg-white rounded-xl shadow-sm p-8 border border-gray-100'>
            <div class='w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mb-5'>
              <span class='text-2xl font-bold text-primary'>3</span>
            </div>
            <h3 class='text-xl font-bold text-gray-900 mb-3'>Ongoing or Done</h3>
            <p class='text-gray-600 leading-relaxed'>Stay with us for maintenance and growth, or take a fully documented handover. Your decision — no lock-in contracts.</p>
          </div>
        </div>
        <div class='text-center mt-10'>
          <a
            href='https://calendly.com/tarun-parashar-alicorninfotech/30min'
            target='_blank'
            rel='noopener noreferrer'
            class='inline-block bg-primary hover:bg-primary-dark text-white font-bold py-3 px-8 rounded-full transition duration-300 text-lg'
          >Book a Free Discovery Call</a>
        </div>
      </div>
    </section>

    <!-- Services Overview -->
    <section class='section-padding px-4 bg-gray-50'>
      <div class='container mx-auto max-w-6xl'>
        <h2
          class='text-3xl md:text-4xl font-bold text-center mb-16 text-gray-900'
        >
          Our Services
        </h2>
        <div class='grid grid-cols-1 md:grid-cols-3 gap-8'>
          {
            services.slice(0, 3).map((service) => (
              <ServiceCard
                title={service.title}
                description={service.description}
                icon={service.icon}
              />
            ))
          }
        </div>
        <div class='text-center mt-12'>
          <a
            href='/services'
            class='inline-block bg-primary hover:bg-primary-dark text-white font-bold py-3 px-8 rounded-full transition duration-300 text-lg'
            >View All Services</a
          >
        </div>
      </div>
    </section>

    <!-- Featured Technologies -->
    <section class='section-padding px-4'>
      <div class='container mx-auto max-w-6xl'>
        <h2
          class='text-3xl md:text-4xl font-bold text-center mb-16 text-gray-900'
        >
          Our Technologies
        </h2>
        <div class='grid grid-cols-1 md:grid-cols-3 gap-8'>
          {
            technology.slice(0,3).map((tech) => (
              <TechCard
                name={tech.name}
                tagline={tech.tagline}
                description={tech.description}
                image={tech.image}
                icon={tech.icon}
              />
            ))
          }
        </div>
        <div class='text-center mt-12'>
          <a
            href='/technology'
            class='inline-block bg-primary hover:bg-primary-dark text-white font-bold py-3 px-8 rounded-full transition duration-300 text-lg'
            >Explore Our Tech Stack</a
          >
        </div>
      </div>
    </section>

    <!-- Recent Projects -->
    <section class='section-padding px-4 bg-gray-50'>
      <div class='container mx-auto max-w-6xl'>
        <h2
          class='text-3xl md:text-4xl font-bold text-center mb-16 text-gray-900'
        >
          Recent Projects
        </h2>
        <div class='grid grid-cols-1 md:grid-cols-2 gap-12'>
          {
            projects.slice(0,2).map((project) => (
              <ProjectCard
                title={project.title}
                category={project.category}
                description={project.description}
                image={project.image}
                client={project.client}
                duration={project.duration}
                technologies={project.technologies}
                slug={project.slug}
              />
            ))
          }
        </div>
        <div class='text-center mt-12'>
          <a
            href='/portfolio'
            class='inline-block bg-primary hover:bg-primary-dark text-white font-bold py-3 px-8 rounded-full transition duration-300 text-lg'
            >View All Projects</a
          >
        </div>
      </div>
    </section>

    <!-- Blog Section -->
    <section class='section-padding px-4'>
      <div class='container mx-auto max-w-6xl'>
        <h2
          class='text-3xl md:text-4xl font-bold text-center mb-4 text-gray-900'
        >
          Latest Insights
        </h2>
        <p class='text-center text-gray-500 mb-14 max-w-2xl mx-auto'>Practical articles on AI, automation, and software development — written by the people doing the work.</p>
        <div class='grid grid-cols-1 md:grid-cols-3 gap-8'>
          {
            [...posts]
              .reverse()
              .slice(0, 3)
              .map((post) => (
                <BlogPostCard
                  title={post.title}
                  excerpt={post.excerpt}
                  image={post.image}
                  date={post.date}
                  author={post.author}
                  slug={post.slug}
                />
              ))
          }
        </div>
        <div class='text-center mt-12'>
          <a
            href='/blog'
            class='inline-block bg-primary hover:bg-primary-dark text-white font-bold py-3 px-8 rounded-full transition duration-300 text-lg'
            >Read More Articles</a
          >
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class='section-padding px-4 bg-primary-50'>
      <div class='container mx-auto max-w-6xl'>
        <h2
          class='text-3xl md:text-4xl font-bold text-center mb-16 text-gray-900'
        >
          What Our Clients Say
        </h2>
        <div class='grid md:grid-cols-3 gap-8'>
          {
            testimonials.map((testimonial) => (
              <TestimonialCard
                quote={testimonial.quote}
                author={testimonial.author}
                position={testimonial.position}
                company={testimonial.company}
              />
            ))
          }
        </div>
      </div>
    </section>

    <!-- Why Alicorn -->
    <section class='section-padding px-4'>
      <div class='container mx-auto max-w-5xl'>
        <h2 class='text-3xl md:text-4xl font-bold text-center mb-4 text-gray-900'>Why clients choose us</h2>
        <p class='text-center text-gray-500 mb-14 max-w-2xl mx-auto'>There are thousands of IT agencies. Here's what's actually different about working with Alicorn.</p>
        <div class='grid grid-cols-1 md:grid-cols-2 gap-8'>
          <div class='flex gap-4 items-start'>
            <div class='flex-shrink-0 w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center'>
              <svg xmlns='http://www.w3.org/2000/svg' class='w-6 h-6 text-primary' fill='currentColor' viewBox='0 0 16 16'>
                <path d='M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6'/>
              </svg>
            </div>
            <div>
              <h3 class='font-bold text-gray-900 text-lg mb-1'>You talk to the founders — always</h3>
              <p class='text-gray-600'>No account managers. No passing you to a junior. Tarun and Ekta are on every project from first call to final delivery.</p>
            </div>
          </div>
          <div class='flex gap-4 items-start'>
            <div class='flex-shrink-0 w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center'>
              <svg xmlns='http://www.w3.org/2000/svg' class='w-6 h-6 text-primary' fill='currentColor' viewBox='0 0 16 16'>
                <path d='M10.854 7.854a.5.5 0 0 0-.708-.708L7.5 9.793 6.354 8.646a.5.5 0 1 0-.708.708l1.5 1.5a.5.5 0 0 0 .708 0z'/><path d='M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1z'/><path d='M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0z'/>
              </svg>
            </div>
            <div>
              <h3 class='font-bold text-gray-900 text-lg mb-1'>Fixed scope, honest estimates</h3>
              <p class='text-gray-600'>We quote accurately, deliver on time, and flag issues early. Nama Supply saw 40% faster complaint resolution. PayNest handles 5,000+ monthly transactions.</p>
            </div>
          </div>
          <div class='flex gap-4 items-start'>
            <div class='flex-shrink-0 w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center'>
              <svg xmlns='http://www.w3.org/2000/svg' class='w-6 h-6 text-primary' fill='currentColor' viewBox='0 0 16 16'>
                <path d='M5 3.5h6A1.5 1.5 0 0 1 12.5 5v6a1.5 1.5 0 0 1-1.5 1.5H5A1.5 1.5 0 0 1 3.5 11V5A1.5 1.5 0 0 1 5 3.5'/><path d='M.5 1a.5.5 0 0 0 0 1H1c.173 0 .345.07.463.2L3.5 4.5V11a3 3 0 0 0 3 3h6a3 3 0 0 0 3-3V5a3 3 0 0 0-3-3H5a3 3 0 0 0-2.9 2.27L.217 1.457A1.5 1.5 0 0 0 1 1.5H.5z'/>
              </svg>
            </div>
            <div>
              <h3 class='font-bold text-gray-900 text-lg mb-1'>Across US, UK, Australia and India</h3>
              <p class='text-gray-600'>We work in IST but communicate across timezones. Our clients include J&J, Twinings Ovaltine, and fast-growing fintechs. Geography is not a problem.</p>
            </div>
          </div>
          <div class='flex gap-4 items-start'>
            <div class='flex-shrink-0 w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center'>
              <svg xmlns='http://www.w3.org/2000/svg' class='w-6 h-6 text-primary' fill='currentColor' viewBox='0 0 16 16'>
                <path d='M6 12.5a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 0 1h-3a.5.5 0 0 1-.5-.5M3 8.062C3 6.76 4.235 5.765 5.53 5.886a26.6 26.6 0 0 0 4.94 0C11.765 5.765 13 6.76 13 8.062v1.157a.93.93 0 0 1-.765.935c-.845.147-2.34.346-4.235.346s-3.39-.2-4.235-.346A.93.93 0 0 1 3 9.219zm4.542-.827a.25.25 0 0 0-.217.068l-.92.9a25 25 0 0 1-1.871-.183.25.25 0 0 0-.068.495c.55.076 1.232.149 2.02.193a.25.25 0 0 0 .189-.071l.754-.736.847 1.71a.25.25 0 0 0 .404.062l.932-.97a25 25 0 0 0 1.922-.188.25.25 0 0 0-.068-.495c-.538.074-1.207.145-1.98.187a.25.25 0 0 0-.166.076l-.754.785-.842-1.7a.25.25 0 0 0-.182-.121'/>
              </svg>
            </div>
            <div>
              <h3 class='font-bold text-gray-900 text-lg mb-1'>AI-ready stack, practical delivery</h3>
              <p class='text-gray-600'>We integrate AI where it genuinely adds value — not as a buzzword. OpenAI, Azure AI, Claude API, custom pipelines. Delivered as working features, not PowerPoints.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <CTA
      title='Ready to Transform Your Business?'
      description="Let's discuss how our innovative IT solutions can drive your business forward."
      buttonText='Get Started'
      buttonLink='/contact-us'
    />
  </main>
</MainLayout>
