---
import { Image } from 'astro:assets';
import MainLayout from '../layouts/MainLayout.astro';
import CTA from '../components/CTA.astro';
import ValueCard from '../components/ValueCard.astro';
import AchievementCard from '../components/AchievementCard.astro';
import AboutBreadcrumbImage from '../assets/images/AboutBreadcrumb.webp';

const companyValues = [
  {
    title: 'Small by design',
    description:
      'We stay small on purpose — it means you always talk to the people who are actually building your product, not an account manager.',
    icon: 'people',
  },
  {
    title: 'Built around your timezone',
    description:
      'We work IST, but our clients are in New York, London and Sydney. We have built our communication and delivery around that reality.',
    icon: 'globe',
  },
  {
    title: 'Honest scoping',
    description:
      'We tell you what a project will actually take — in time and cost — before we start. No surprise invoices, no scope creep without your approval.',
    icon: 'shield-check',
  },
  {
    title: 'Outcomes over outputs',
    description:
      'We measure success by what changes for your business, not by lines of code written or tickets closed.',
    icon: 'graph-up-arrow',
  },
];

const achievements = [
  {
    id: 1,
    title: 'Projects Delivered',
    value: '14+',
    icon: 'clipboard-check',
  },
  {
    id: 2,
    title: 'Years in Operation',
    value: '5+',
    icon: 'calendar',
  },
  {
    id: 3,
    title: 'Countries Served',
    value: '4',
    icon: 'globe',
  },
  {
    id: 4,
    title: 'Active Enterprise Clients',
    value: '2 Ongoing',
    icon: 'building',
  },
];
---

<MainLayout
  title='About Us | Alicorn Infotech'
  description='Alicorn Infotech is a small, founder-led software development team based in Pune, India. We build web and mobile products, integrate AI and automate workflows for startups and businesses in the US, UK, Australia and India. Meet the founders — Tarun Parashar and Ekta Agrawal.'
  canonicalUrl='https://alicorninfotech.com/about-us'
>
  <main class='bg-gradient-to-b from-gray-100 to-white'>
    <!-- Hero Section -->
    <section
      class='relative h-[50vh] min-h-[400px] flex items-center justify-center'
      aria-label='About Us Hero Section'
    >
      <Image
        src={AboutBreadcrumbImage}
        alt='About Alicorn Infotech'
        width={1920}
        height={1080}
        class='absolute inset-0 w-full h-full object-cover'
      />
      <div class='absolute inset-0 bg-primary opacity-70'></div>
      <div class='relative z-10 text-center text-white px-4'>
        <h1 class='text-4xl md:text-6xl font-bold mb-4'>
          About Alicorn Infotech
        </h1>
        <p class='text-xl md:text-2xl mb-8'>A small team. Real projects. Clients across four continents.</p>
      </div>
    </section>

    <!-- Founding Story -->
    <section class='section-padding px-4'>
      <div class='container mx-auto max-w-4xl text-center'>
        <h2 class='text-3xl md:text-4xl font-bold mb-6 text-gray-900'>
          Our Story
        </h2>
        <p class='text-xl text-gray-700 leading-relaxed mb-6'>
          We started Alicorn in 2020 because we kept seeing startups and growing businesses pay large agency prices for work that could be done better — and faster — by a small, dedicated team that actually cared about the outcome. That is still what we do.
        </p>
        <p class='text-lg text-gray-600 leading-relaxed'>
          Today we work with clients in the US, UK, Australia and India — building web and mobile products, integrating AI and automation, and running QA. The co-founders are involved in every project. The people you speak to are the same people building your product.
        </p>
      </div>
    </section>

    <!-- Company Values -->
    <section class='section-padding px-4 bg-gray-50'>
      <div class='container mx-auto max-w-6xl'>
        <h2
          class='text-3xl md:text-4xl font-bold text-center mb-12 text-gray-900'
        >
          How We Work
        </h2>
        <div class='grid grid-cols-1 md:grid-cols-2 gap-8'>
          {
            companyValues.map((value) => (
              <ValueCard
                title={value.title}
                description={value.description}
                icon={value.icon}
              />
            ))
          }
        </div>
      </div>
    </section>

    <!-- Achievements -->
    <section class='section-padding px-4'>
      <div class='container mx-auto max-w-6xl'>
        <h2
          class='text-3xl md:text-4xl font-bold text-center mb-12 text-gray-900'
        >
          Our Achievements
        </h2>
        <div
          class='grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6 md:gap-8'
        >
          {
            achievements.map((achievement) => (
              <AchievementCard
                id={achievement.id}
                title={achievement.title}
                value={achievement.value}
                icon={achievement.icon}
              />
            ))
          }
        </div>
      </div>
    </section>

    <!-- Meet the Team -->
    <section class='section-padding px-4 bg-primary-50'>
      <div class='container mx-auto max-w-5xl'>
        <h2 class='text-gray-900 text-3xl md:text-4xl font-bold text-center mb-4'>
          Meet the Team
        </h2>
        <p class='text-center text-gray-500 mb-12 max-w-2xl mx-auto'>The people you speak to in your first call are the same people shipping your code. No handoffs. No account managers.</p>
        <div class='grid md:grid-cols-2 gap-10'>
          <!-- Tarun -->
          <div class='bg-white rounded-2xl shadow-md overflow-hidden'>
            <div class='h-3 bg-gradient-to-r from-primary to-primary-dark'></div>
            <div class='p-8 flex flex-col items-center text-center'>
              <img
  src="/tarun.jpeg"
  alt="Ekta Agrawal"
  class="w-24 h-24 rounded-full object-cover mb-5 shadow-lg"
/>
              <h3 class='text-2xl font-bold text-gray-900 mb-1'>Tarun Parashar</h3>
              <p class='text-primary font-semibold mb-1'>Co-Founder & Tech Lead</p>
              <p class='text-gray-400 text-sm mb-4'>Business Automation · Full-Stack · AI Integration</p>
              <p class='text-gray-600 leading-relaxed mb-6'>
                Tarun leads delivery across all client projects. With deep expertise in business automation, Power Platform and backend development, he has built solutions for clients in finance, supply chain and healthcare across the US, UK and India. He is directly reachable on every engagement — not through a PM.
              </p>
              <div class='flex gap-4'>
                <a
                  href='https://www.linkedin.com/in/tarun-parashar'
                  target='_blank'
                  rel='noopener noreferrer'
                  class='inline-flex items-center gap-2 bg-primary text-white font-medium px-5 py-2 rounded-full hover:bg-primary-dark transition-colors text-sm'
                >
                  <svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' fill='currentColor' viewBox='0 0 16 16'><path d='M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z'/></svg>
                  LinkedIn
                </a>
                <a
                  href='mailto:contact@alicorninfotech.com'
                  class='inline-flex items-center gap-2 border border-primary text-primary font-medium px-5 py-2 rounded-full hover:bg-primary/5 transition-colors text-sm'
                >
                  Email Tarun
                </a>
              </div>
            </div>
          </div>
          <!-- Ekta -->
          <div class='bg-white rounded-2xl shadow-md overflow-hidden'>
            <div class='h-3 bg-gradient-to-r from-primary to-primary-dark'></div>
            <div class='p-8 flex flex-col items-center text-center'>
              <img
  src="/ekta.jpeg"
  alt="Ekta Agrawal"
  class="w-24 h-24 rounded-full object-cover mb-5 shadow-lg"
/>
              <h3 class='text-2xl font-bold text-gray-900 mb-1'>Ekta Agrawal</h3>
              <p class='text-primary font-semibold mb-1'>Co-Founder & Design Lead</p>
              <p class='text-gray-400 text-sm mb-4'>UI/UX Design · Project Management · Client Strategy</p>
              <p class='text-gray-600 leading-relaxed mb-6'>
                Ekta oversees UI/UX design, project management and client communication. She brings a user-first approach to every product — ensuring that what gets built is both technically solid and genuinely enjoyable to use. She has prior international experience working across Europe and brings a global perspective to every client engagement.
              </p>
              <div class='flex gap-4'>
                <a
                  href='https://www.linkedin.com/in/ekta-agrawal-8a491176'
                  target='_blank'
                  rel='noopener noreferrer'
                  class='inline-flex items-center gap-2 bg-primary text-white font-medium px-5 py-2 rounded-full hover:bg-primary-dark transition-colors text-sm'
                >
                  <svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' fill='currentColor' viewBox='0 0 16 16'><path d='M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z'/></svg>
                  LinkedIn
                </a>
                <a
                  href='mailto:contact@alicorninfotech.com'
                  class='inline-flex items-center gap-2 border border-primary text-primary font-medium px-5 py-2 rounded-full hover:bg-primary/5 transition-colors text-sm'
                >
                  Email Ekta
                </a>
              </div>
            </div>
          </div>
        </div>
       
      </div>
    </section>

    <!-- CTA Section -->
    <CTA
      title='Ready to Transform Your Business?'
      description="Let's discuss how our innovative IT solutions can drive your business forward."
      buttonText='Get in Touch'
      buttonLink='/contact-us'
    />
  </main>
</MainLayout>
