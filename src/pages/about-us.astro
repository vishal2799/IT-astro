---
import { Image } from 'astro:assets';
import MainLayout from '../layouts/MainLayout.astro';
import CTA from '../components/CTA.astro';
import ValueCard from '../components/ValueCard.astro';
import AchievementCard from '../components/AchievementCard.astro';
import AboutBreadcrumbImage from '../assets/images/AboutBreadcrumb.webp';

const companyValues = [
  {
    title: 'Small by design',
    description:
      'We stay small on purpose — it means you always talk to the people who are actually building your product, not an account manager.',
    icon: 'people',
  },
  {
    title: 'Built around your timezone',
    description:
      'We work IST, but our clients are in New York, London and Sydney. We have built our communication and delivery around that reality.',
    icon: 'globe',
  },
  {
    title: 'Honest scoping',
    description:
      'We tell you what a project will actually take — in time and cost — before we start. No surprise invoices, no scope creep without your approval.',
    icon: 'shield-check',
  },
  {
    title: 'Outcomes over outputs',
    description:
      'We measure success by what changes for your business, not by lines of code written or tickets closed.',
    icon: 'graph-up-arrow',
  },
];

const achievements = [
  {
    id: 1,
    title: 'Projects Delivered',
    value: '14+',
    icon: 'clipboard-check',
  },
  {
    id: 2,
    title: 'Years in Operation',
    value: '5+',
    icon: 'calendar',
  },
  {
    id: 3,
    title: 'Countries Served',
    value: '4',
    icon: 'globe',
  },
  {
    id: 4,
    title: 'Active Enterprise Clients',
    value: '2 Ongoing',
    icon: 'building',
  },
];
---

<MainLayout
  title='About Us | Alicorn Infotech'
  description='Learn about Alicorn Infotech, our mission, values, and achievements in delivering innovative technology solutions.'
  canonicalUrl='https://alicorninfotech.com/about-us'
>
  <main class='bg-gradient-to-b from-gray-100 to-white'>
    <!-- Hero Section -->
    <section
      class='relative h-[50vh] min-h-[400px] flex items-center justify-center'
      aria-label='About Us Hero Section'
    >
      <Image
        src={AboutBreadcrumbImage}
        alt='About Alicorn Infotech'
        width={1920}
        height={1080}
        class='absolute inset-0 w-full h-full object-cover'
      />
      <div class='absolute inset-0 bg-primary opacity-70'></div>
      <div class='relative z-10 text-center text-white px-4'>
        <h1 class='text-4xl md:text-6xl font-bold mb-4'>
          About Alicorn Infotech
        </h1>
        <p class='text-xl md:text-2xl mb-8'>A small team. Real projects. Clients across four continents.</p>
      </div>
    </section>

    <!-- Founding Story -->
    <section class='section-padding px-4'>
      <div class='container mx-auto max-w-4xl text-center'>
        <h2 class='text-3xl md:text-4xl font-bold mb-6 text-gray-900'>
          Our Story
        </h2>
        <p class='text-xl text-gray-700 leading-relaxed mb-6'>
          We started Alicorn in 2020 because we kept seeing startups and growing businesses pay large agency prices for work that could be done better — and faster — by a small, dedicated team that actually cared about the outcome. That is still what we do.
        </p>
        <p class='text-lg text-gray-600 leading-relaxed'>
          Today we work with clients in the US, UK, Australia and India — building web and mobile products, integrating AI and automation, and running QA. The co-founders are involved in every project. The people you speak to are the same people building your product.
        </p>
      </div>
    </section>

    <!-- Company Values -->
    <section class='section-padding px-4 bg-gray-50'>
      <div class='container mx-auto max-w-6xl'>
        <h2
          class='text-3xl md:text-4xl font-bold text-center mb-12 text-gray-900'
        >
          How We Work
        </h2>
        <div class='grid grid-cols-1 md:grid-cols-2 gap-8'>
          {
            companyValues.map((value) => (
              <ValueCard
                title={value.title}
                description={value.description}
                icon={value.icon}
              />
            ))
          }
        </div>
      </div>
    </section>

    <!-- Achievements -->
    <section class='section-padding px-4'>
      <div class='container mx-auto max-w-6xl'>
        <h2
          class='text-3xl md:text-4xl font-bold text-center mb-12 text-gray-900'
        >
          Our Achievements
        </h2>
        <div
          class='grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6 md:gap-8'
        >
          {
            achievements.map((achievement) => (
              <AchievementCard
                id={achievement.id}
                title={achievement.title}
                value={achievement.value}
                icon={achievement.icon}
              />
            ))
          }
        </div>
      </div>
    </section>

    <!-- Meet the Team -->
    <section class='section-padding px-4 bg-primary-50'>
      <div class='container mx-auto max-w-5xl'>
        <h2 class='text-gray-900 text-3xl md:text-4xl font-bold text-center mb-12'>
          Meet the Team
        </h2>
        <div class='grid md:grid-cols-2 gap-10'>
          <!-- Tarun -->
          <div class='bg-white rounded-xl shadow-md p-8 flex flex-col items-center text-center'>
            <div class='w-24 h-24 rounded-full bg-primary/10 flex items-center justify-center mb-4'>
              <span class='text-3xl font-bold text-primary'>T</span>
            </div>
            <h3 class='text-2xl font-bold text-gray-900 mb-1'>Tarun Parashar</h3>
            <p class='text-primary font-semibold mb-3'>Co-Founder & Tech Lead</p>
            <p class='text-gray-600 leading-relaxed mb-4'>
              Tarun leads delivery across all client projects. With deep expertise in business automation, Power Platform and backend development, he has built solutions for clients in finance, supply chain and healthcare across the US, UK and India.
            </p>
            <a
              href='https://www.linkedin.com/in/tarun-parashar'
              target='_blank'
              rel='noopener noreferrer'
              class='inline-flex items-center text-primary font-medium hover:text-primary-dark transition-colors'
            >
              Connect on LinkedIn →
            </a>
          </div>
          <!-- Ekta -->
          <div class='bg-white rounded-xl shadow-md p-8 flex flex-col items-center text-center'>
            <div class='w-24 h-24 rounded-full bg-primary/10 flex items-center justify-center mb-4'>
              <span class='text-3xl font-bold text-primary'>E</span>
            </div>
            <h3 class='text-2xl font-bold text-gray-900 mb-1'>Ekta Agrawal</h3>
            <p class='text-primary font-semibold mb-3'>Co-Founder & Design Lead</p>
            <p class='text-gray-600 leading-relaxed mb-4'>
              Ekta oversees UI/UX design and client communication. She brings a user-first approach to every product — ensuring that what gets built is both technically solid and genuinely enjoyable to use.
            </p>
            <a
              href='https://www.linkedin.com/in/ekta-agrawal-8a491176'
              target='_blank'
              rel='noopener noreferrer'
              class='inline-flex items-center text-primary font-medium hover:text-primary-dark transition-colors'
            >
              Connect on LinkedIn →
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <CTA
      title='Ready to Transform Your Business?'
      description="Let's discuss how our innovative IT solutions can drive your business forward."
      buttonText='Get in Touch'
      buttonLink='/contact-us'
    />
  </main>
</MainLayout>
