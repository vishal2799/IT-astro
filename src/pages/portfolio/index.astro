---
import MainLayout from '../../layouts/MainLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { projects } from '../../constants';
import ProjectBreadcrumbImage from '../../assets/images/ProjectBreadcrumb.webp';
import { Image } from 'astro:assets';
import CTA from '../../components/CTA.astro';

// ─── Tab grouping config ──────────────────────────────────────────────────────
// Maps a display label to a list of substrings matched against project.category.
// Order here controls tab order. Add new categories here as your portfolio grows.
const TAB_GROUPS: Record<string, string[]> = {
  'All':              [],
  'AI & ML':          ['generative ai', 'llm', 'machine learning', 'rag', 'ai integration'],
  'Web & Mobile':     ['web development', 'web application', 'mobile app', 'fintech suite', 'landing page'],
  'Power Platform':   ['business process automation', 'power platform'],
  'Enterprise':       ['enterprise application', 'workflow automation'],
  'E-Commerce':       ['e-commerce'],
  'UI/UX Design':     ['ui/ux design'],
  'DevOps':           ['devops', 'ci/cd'],
  'SEO': ['seo', 'digital visibility'],
};

// Derive which tabs actually have matching projects (skip empty tabs except All)
const activeTabs = Object.entries(TAB_GROUPS).filter(([label, keywords]) => {
  if (label === 'All') return true;
  return projects.some((p) =>
    keywords.some((kw) => p.category.toLowerCase().includes(kw))
  );
}).map(([label]) => label);
---

<MainLayout
  title='Portfolio | Alicorn Infotech'
  description='Explore our portfolio of successful projects across various industries and technologies.'
  canonicalUrl='https://alicorninfotech.com/projects'
>
  <main class='bg-gradient-to-b from-gray-100 to-white'>

    <!-- Hero Section -->
    <section class='relative h-[40vh] min-h-[300px] flex items-center justify-center'>
      <Image
        src={ProjectBreadcrumbImage}
        alt='Alicorn Infotech Projects'
        width={1920}
        height={1080}
        class='absolute inset-0 w-full h-full object-cover'
      />
      <div class='absolute inset-0 bg-black opacity-50'></div>
      <div class='relative z-10 text-center text-white px-4'>
        <h1 class='text-4xl md:text-6xl font-bold mb-4'>Portfolio</h1>
        <p class='text-xl md:text-2xl mb-8'>Innovative Solutions Driving Business Success</p>
      </div>
    </section>

    <!-- Projects Grid -->
    <section class='section-padding px-4'>
      <div class='container mx-auto max-w-6xl'>

        <!-- Filter Tabs — generated from TAB_GROUPS + live project data -->
        <div class='flex flex-wrap justify-center gap-3 mb-12' id='filter-tabs'>
          {activeTabs.map((tab, i) => (
            <button
              class={`filter-btn px-5 py-2 rounded-full border-2 border-primary font-semibold text-sm transition-all duration-200 hover:bg-primary hover:text-white focus:outline-none ${i === 0 ? 'bg-primary text-white' : 'text-primary'}`}
              data-filter={tab}
            >
              {tab}
            </button>
          ))}
        </div>

        <!-- Project count indicator -->
        <p class='text-center text-sm text-gray-500 mb-8' id='project-count'>
          Showing all {projects.length} projects
        </p>

        <div class='grid grid-cols-1 md:grid-cols-2 gap-12' id='projects-grid'>
          {projects.map((project, index) => (
            <ProjectCard
              title={project.title}
              category={project.category}
              description={project.description}
              image={project.image}
              client={project.client}
              duration={project.duration}
              technologies={project.technologies}
              slug={project.slug}
              index={index}
            />
          ))}
        </div>

        <!-- Empty state -->
        <div id='empty-state' class='hidden text-center py-20'>
          <p class='text-gray-400 text-lg'>No projects in this category yet.</p>
        </div>

      </div>
    </section>

    <CTA
      title='Ready to Start Your Project?'
      description='Lets discuss how we can bring your ideas to life and drive your business forward.'
      buttonText='Get in Touch'
      buttonLink='/contact-us'
    />
  </main>
</MainLayout>

<script>
  // ─── Tab keyword groups (mirrors server-side config) ─────────────────────────
  // Kept in sync manually — if you add a group above, add it here too.
  const TAB_KEYWORDS: Record<string, string[]> = {
    'All':            [],
    'AI & ML':        ['generative ai', 'llm', 'machine learning', 'rag', 'ai integration'],
    'Web & Mobile':   ['web development', 'web application', 'mobile app', 'fintech suite', 'landing page'],
    'Power Platform': ['business process automation', 'power platform'],
    'Enterprise':     ['enterprise application', 'workflow automation'],
    'E-Commerce':     ['e-commerce'],
    'UI/UX Design':   ['ui/ux design'],
    'DevOps':         ['devops', 'ci/cd'],
    'SEO':            ['seo', 'digital visibility'], 
  };

  const tabs       = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards      = document.querySelectorAll<HTMLElement>('#projects-grid > *');
  const countEl    = document.getElementById('project-count')!;
  const emptyEl    = document.getElementById('empty-state')!;

  // Remove AOS attributes so cards don't re-animate on filter
  cards.forEach((card) => {
    card.removeAttribute('data-aos');
    card.removeAttribute('data-aos-delay');
    card.style.opacity   = '1';
    card.style.transform = 'none';
    card.style.transition = 'opacity 0.2s ease, transform 0.2s ease';
  });

  function applyFilter(activeTab: string) {
    const keywords = TAB_KEYWORDS[activeTab] ?? [];
    let visible = 0;

    cards.forEach((card) => {
      const cat = (card.dataset.category ?? '').toLowerCase();
      const show = activeTab === 'All' || keywords.some((kw) => cat.includes(kw));

      if (show) {
        card.style.display = '';
        // Tiny delay so display:'' takes effect before opacity transition
        requestAnimationFrame(() => { card.style.opacity = '1'; card.style.transform = 'none'; });
        visible++;
      } else {
        card.style.opacity   = '0';
        card.style.transform = 'translateY(4px)';
        setTimeout(() => { if (card.style.opacity === '0') card.style.display = 'none'; }, 200);
      }
    });

    // Update count label
    const total = cards.length;
    countEl.textContent = activeTab === 'All'
      ? `Showing all ${total} projects`
      : `Showing ${visible} of ${total} projects`;

    // Show/hide empty state
    emptyEl.classList.toggle('hidden', visible > 0);
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => t.classList.remove('bg-primary', 'text-white'));
      tab.classList.add('bg-primary', 'text-white');
      applyFilter(tab.dataset.filter ?? 'All');
    });
  });

  // Initialise
  applyFilter('All');
</script>