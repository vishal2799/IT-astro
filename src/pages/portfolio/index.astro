---
import MainLayout from '../../layouts/MainLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { projects } from '../../constants';
import ProjectBreadcrumbImage from '../../assets/images/ProjectBreadcrumb.webp';
import { Image } from 'astro:assets';
import CTA from '../../components/CTA.astro';
---

<MainLayout
  title='Portfolio | Alicorn Infotech'
  description='Explore our portfolio of successful projects across various industries and technologies.'
  canonicalUrl='https://alicorninfotech.com/projects'
>
  <main class='bg-gradient-to-b from-gray-100 to-white'>
    <!-- Hero Section -->
    <section
      class='relative h-[40vh] min-h-[300px] flex items-center justify-center'
    >
      <Image
        src={ProjectBreadcrumbImage}
        alt='Alicorn Infotech Projects'
        width={1920}
        height={1080}
        class='absolute inset-0 w-full h-full object-cover'
      />
      <div class='absolute inset-0 bg-black opacity-50'></div>
      <div class='relative z-10 text-center text-white px-4'>
        <h1 class='text-4xl md:text-6xl font-bold mb-4'>Portfolio</h1>
        <p class='text-xl md:text-2xl mb-8'>
          Innovative Solutions Driving Business Success
        </p>
      </div>
    </section>

    <!-- Projects Grid -->
    <section class='section-padding px-4'>
      <div class='container mx-auto max-w-6xl'>

        <!-- Filter Tabs -->
        <div class='flex flex-wrap justify-center gap-3 mb-12' id='filter-tabs'>
          {['All', 'Web & Mobile', 'Power Platform', 'Enterprise Tools', 'E-Commerce', 'AI & Automation'].map((tab) => (
            <button
              class='filter-btn px-5 py-2 rounded-full border-2 border-primary text-primary font-semibold text-sm transition-all duration-200 hover:bg-primary hover:text-white focus:outline-none'
              data-filter={tab}
            >
              {tab}
            </button>
          ))}
        </div>

        <div class='grid grid-cols-1 md:grid-cols-2 gap-12' id='projects-grid'>
          {
            projects.map((project, index) => (
              <ProjectCard
                title={project.title}
                category={project.category}
                description={project.description}
                image={project.image}
                client={project.client}
                duration={project.duration}
                technologies={project.technologies}
                slug={project.slug}
                index={index}
              />
            ))
          }
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <CTA
      title='Ready to Start Your Project?'
      description='Lets discuss how we can bring your ideas to life and drive your business forward.'
      buttonText='Get in Touch'
      buttonLink='/contact-us'
    />
  </main>
</MainLayout>

<script>
  const filterRules: Record<string, { cats: string[]; techs: string[] }> = {
    'All':              { cats: [], techs: [] },
    'Web & Mobile':     { cats: ['website', 'web application', 'landing page', 'fintech suite', 'mobile app'], techs: ['react native', 'reactjs', 'next.js', 'flutter', 'swift', 'kotlin', 'node.js', 'wordpress', 'elementor', 'django'] },
    'Power Platform':   { cats: ['power platform', 'business process automation'], techs: ['powerapps', 'power apps', 'power automate', 'power bi', 'sharepoint'] },
    'Enterprise Tools': { cats: ['enterprise', 'practice management', 'internal tool', 'workflow automation'], techs: ['sharepoint', 'k2 nintex', 'asp.net', 'sql server', 'nintex'] },
    'E-Commerce':       { cats: ['e-commerce'], techs: ['woocommerce', 'shopify', 'magento'] },
    'AI & Automation':  { cats: ['automation', 'power platform'], techs: ['power automate', 'uipath', 'automation anywhere', 'k2 nintex'] },
  };

  const tabs  = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('#projects-grid > div[data-category]');

  // Strip AOS from all cards immediately — we don't want scroll-hiding on a filter page
  cards.forEach((card) => {
    card.removeAttribute('data-aos');
    card.removeAttribute('data-aos-delay');
    card.style.opacity   = '1';
    card.style.transform = 'none';
    card.style.transition = 'opacity 0.2s ease, transform 0.2s ease';
  });

  // Set first tab active on load
  tabs[0]?.classList.add('bg-primary', 'text-white');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const filter = tab.dataset.filter ?? 'All';

      tabs.forEach((t) => t.classList.remove('bg-primary', 'text-white'));
      tab.classList.add('bg-primary', 'text-white');

      cards.forEach((card) => {
        if (filter === 'All') {
          card.style.display   = '';
          card.style.opacity   = '1';
          card.style.transform = 'none';
          return;
        }

        const { cats, techs } = filterRules[filter] ?? { cats: [], techs: [] };
        const cardCat  = (card.dataset.category     ?? '').toLowerCase();
        const cardTech = (card.dataset.technologies ?? '').toLowerCase();
        const visible  = cats.some((kw) => cardCat.includes(kw)) || techs.some((kw) => cardTech.includes(kw));

        card.style.display   = visible ? ''     : 'none';
        card.style.opacity   = visible ? '1'    : '';
        card.style.transform = visible ? 'none' : '';
      });
    });
  });
</script>
