---
import MainLayout from '../../layouts/MainLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { projects } from '../../constants';
import ProjectBreadcrumbImage from '../../assets/images/ProjectBreadcrumb.webp';
import { Image } from 'astro:assets';
import CTA from '../../components/CTA.astro';
---

<MainLayout
  title='Portfolio | Alicorn Infotech'
  description='Explore our portfolio of successful projects across various industries and technologies.'
  canonicalUrl='https://alicorninfotech.com/projects'
>
  <main class='bg-gradient-to-b from-gray-100 to-white'>
    <!-- Hero Section -->
    <section
      class='relative h-[40vh] min-h-[300px] flex items-center justify-center'
    >
      <Image
        src={ProjectBreadcrumbImage}
        alt='Alicorn Infotech Projects'
        width={1920}
        height={1080}
        class='absolute inset-0 w-full h-full object-cover'
      />
      <div class='absolute inset-0 bg-black opacity-50'></div>
      <div class='relative z-10 text-center text-white px-4'>
        <h1 class='text-4xl md:text-6xl font-bold mb-4' data-aos="fade-down">Portfolio</h1>
        <p class='text-xl md:text-2xl mb-8' data-aos="fade-down" data-aos-delay="200">
          Innovative Solutions Driving Business Success
        </p>
      </div>
    </section>

    <!-- Projects Grid -->
    <section class='section-padding px-4'>
      <div class='container mx-auto max-w-6xl'>

        <!-- Filter Tabs -->
        <div class='flex flex-wrap justify-center gap-3 mb-12' id='filter-tabs'>
          {['All', 'Web & Mobile', 'Power Platform', 'Enterprise Tools', 'E-Commerce', 'AI & Automation'].map((tab) => (
            <button
              class='filter-btn px-5 py-2 rounded-full border-2 border-primary text-primary font-semibold text-sm transition-all duration-200 hover:bg-primary hover:text-white focus:outline-none'
              data-filter={tab}
            >
              {tab}
            </button>
          ))}
        </div>

        <div class='grid grid-cols-1 md:grid-cols-2 gap-12' id='projects-grid'>
          {
            projects.map((project, index) => (
              <ProjectCard
                title={project.title}
                category={project.category}
                description={project.description}
                image={project.image}
                client={project.client}
                duration={project.duration}
                technologies={project.technologies}
                slug={project.slug}
                index={index}
              />
            ))
          }
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <CTA
      title='Ready to Start Your Project?'
      description='Lets discuss how we can bring your ideas to life and drive your business forward.'
      buttonText='Get in Touch'
      buttonLink='/contact-us'
    />
  </main>
</MainLayout>

<script>
  // Map filter tab labels to category keywords
  const filterMap: Record<string, string[]> = {
    'All': [],
    'Web & Mobile': ['website', 'web', 'mobile', 'landing page', 'wordpress', 'ecommerce', 'e-commerce', 'fintech'],
    'Power Platform': ['power platform', 'power apps', 'power automate', 'sharepoint'],
    'Enterprise Tools': ['.net', 'enterprise', 'hr management', 'business process'],
    'E-Commerce': ['e-commerce', 'ecommerce', 'woocommerce', 'shopify'],
    'AI & Automation': ['automation', 'rpa', 'ai', 'bpm', 'workflow'],
  };

  const tabs = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('#projects-grid > div');

  // Set first tab active
  tabs[0]?.classList.add('bg-primary', 'text-white');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const filter = tab.dataset.filter || 'All';

      // Update active styles
      tabs.forEach((t) => t.classList.remove('bg-primary', 'text-white'));
      tab.classList.add('bg-primary', 'text-white');

      // Filter cards
      cards.forEach((card) => {
        if (filter === 'All') {
          card.style.display = '';
          return;
        }
        const keywords = filterMap[filter] || [];
        const cardText = card.innerText.toLowerCase();
        const match = keywords.some((kw) => cardText.includes(kw));
        card.style.display = match ? '' : 'none';
      });
    });
  });
</script>
